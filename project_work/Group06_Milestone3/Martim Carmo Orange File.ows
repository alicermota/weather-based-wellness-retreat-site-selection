		<properties node_id="20" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x04\x00\x00\x05\xa0\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83', 'scriptLibrary': [{'name': 'Default', 'script': 'out_data = in_data\n', 'filename': None}], 'scriptText': 'import numpy as np\nfrom scipy import stats\nfrom Orange.data import Table, Domain, ContinuousVariable\n\nall_data = in_data\nzone_values = list(set([str(inst["zone"]) for inst in all_data]))\nguarda_mask = [str(inst["zone"]) == zone_values[0] for inst in all_data]\nvilareal_mask = [str(inst["zone"]) == zone_values[1] for inst in all_data]\n\ng_p = np.array([float(inst["precipitation_sum"]) for inst, m in zip(all_data, guarda_mask) if m])\nvr_p = np.array([float(inst["precipitation_sum"]) for inst, m in zip(all_data, vilareal_mask) if m])\n\ng_cv = np.std(g_p, ddof=1) / np.mean(g_p) * 100\nvr_cv = np.std(vr_p, ddof=1) / np.mean(vr_p) * 100\nd = abs(np.mean(vr_p) - np.mean(g_p)) / np.sqrt((np.std(g_p,ddof=1)**2 + np.std(vr_p,ddof=1)**2) / 2)\n\ngy = {}; vry = {}\nfor inst, gm, vrm in zip(all_data, guarda_mask, vilareal_mask):\n    try:\n        yr = int(str(inst["date"])[:4]); rd = float(inst["precipitation_sum"]) &gt;= 1.0\n        if gm: gy[yr] = gy.get(yr, 0) + (1 if rd else 0)\n        if vrm: vry[yr] = vry.get(yr, 0) + (1 if rd else 0)\n    except: pass\n\nga = np.array([v for k,v in sorted(gy.items()) if k &lt; 2026])\nvra = np.array([v for k,v in sorted(vry.items()) if k &lt; 2026])\n\ndom = Domain([\n    ContinuousVariable("Guarda_CV_daily_pct"), ContinuousVariable("VilaReal_CV_daily_pct"),\n    ContinuousVariable("Cohens_d"), ContinuousVariable("Guarda_mean_annual_rain_days"),\n    ContinuousVariable("VilaReal_mean_annual_rain_days"),\n    ContinuousVariable("Guarda_CV_annual_pct"), ContinuousVariable("VilaReal_CV_annual_pct"),\n])\nout_data = Table.from_numpy(dom, np.array([[g_cv, vr_cv, d, np.mean(ga), np.mean(vra),\n    np.std(ga,ddof=1)/np.mean(ga)*100, np.std(vra,ddof=1)/np.mean(vra)*100]]))\nprint("CV Guarda:", round(g_cv,1), "CV VR:", round(vr_cv,1), "d:", round(d,3))', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xab\x00\x00\x00k\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="21" format="literal">{'auto_commit': True, 'color_by_class': True, 'controlAreaVisible': True, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x04\x00\x00\x05\xa0\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83', 'select_rows': True, 'show_attribute_labels': True, 'show_distributions': False, 'stored_selection': {'rows': [], 'columns': []}, 'stored_sort': [], '__version__': 1}</properties>
		<properties node_id="22" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x04\x00\x00\x05\xa0\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83', 'scriptLibrary': [{'name': 'Default', 'script': 'out_data = in_data\n', 'filename': None}], 'scriptText': 'import numpy as np\nfrom scipy import stats\nfrom Orange.data import Table, Domain, ContinuousVariable\n\nall_data = in_data\nmonthly = {}\nfor inst in all_data:\n    try:\n        ds = str(inst["date"]); mo = int(ds[5:7]); yr = int(ds[:4])\n        monthly[(yr,mo)] = monthly.get((yr,mo), 0) + float(inst["precipitation_sum"])\n    except: pass\n\nmg = {m: [] for m in range(1,13)}\nfor (yr, mo), val in monthly.items(): mg[mo].append(val)\nf_stat, p_val = stats.f_oneway(*[mg[m] for m in range(1,13)])\nn_obs = sum(len(mg[m]) for m in range(1,13))\n\nout_data = Table.from_numpy(Domain([ContinuousVariable("F_statistic"), ContinuousVariable("p_value"), ContinuousVariable("n_obs")]), np.array([[f_stat, p_val, n_obs]]))\nprint("ANOVA F=", round(f_stat,3), "p=", round(p_val,6))', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xab\x00\x00\x00k\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="23" format="literal">{'auto_commit': True, 'color_by_class': True, 'controlAreaVisible': True, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x04\x00\x00\x05\xa0\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83', 'select_rows': True, 'show_attribute_labels': True, 'show_distributions': False, 'stored_selection': {'rows': [], 'columns': []}, 'stored_sort': [], '__version__': 1}</properties>
		<properties node_id="24" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x04\x00\x00\x05\xa0\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83', 'scriptLibrary': [{'name': 'Default', 'script': 'out_data = in_data\n', 'filename': None}], 'scriptText': 'import numpy as np\nfrom scipy import stats\nfrom Orange.data import Table, Domain, ContinuousVariable\n\nall_data = in_data\nmonthly = {}\nfor inst in all_data:\n    try:\n        ds = str(inst["date"]); mo = int(ds[5:7]); yr = int(ds[:4])\n        monthly[(yr,mo)] = monthly.get((yr,mo), 0) + float(inst["precipitation_sum"])\n    except: pass\n\nmg = {m: [] for m in range(1,13)}\nfor (yr, mo), val in monthly.items(): mg[mo].append(val)\nf_stat, p_val = stats.f_oneway(*[mg[m] for m in range(1,13)])\nn_obs = sum(len(mg[m]) for m in range(1,13))\n\nout_data = Table.from_numpy(Domain([ContinuousVariable("F_statistic"), ContinuousVariable("p_value"), ContinuousVariable("n_obs")]), np.array([[f_stat, p_val, n_obs]]))\nprint("ANOVA F=", round(f_stat,3), "p=", round(p_val,6))', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xab\x00\x00\x00k\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="25" format="literal">{'auto_commit': True, 'color_by_class': True, 'controlAreaVisible': True, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x04\x00\x00\x05\xa0\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83', 'select_rows': True, 'show_attribute_labels': True, 'show_distributions': False, 'stored_selection': {'rows': [], 'columns': []}, 'stored_sort': [], '__version__': 1}</properties>
		<properties node_id="26" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x04\x00\x00\x05\xa0\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83', 'scriptLibrary': [{'name': 'Default', 'script': 'out_data = in_data\n', 'filename': None}], 'scriptText': 'import numpy as np\nfrom scipy import stats\nfrom Orange.data import Table, Domain, ContinuousVariable\n\nall_data = in_data\nzone_values = list(set([str(inst["zone"]) for inst in all_data]))\nguarda_mask = [str(inst["zone"]) == zone_values[0] for inst in all_data]\nvilareal_mask = [str(inst["zone"]) == zone_values[1] for inst in all_data]\n\ng_p = np.array([float(inst["precipitation_sum"]) for inst, m in zip(all_data, guarda_mask) if m])\nvr_p = np.array([float(inst["precipitation_sum"]) for inst, m in zip(all_data, vilareal_mask) if m])\n\ng_ci = stats.t.interval(0.95, df=len(g_p)-1, loc=np.mean(g_p), scale=stats.sem(g_p))\nvr_ci = stats.t.interval(0.95, df=len(vr_p)-1, loc=np.mean(vr_p), scale=stats.sem(vr_p))\n\ngy = {}; vry = {}\nfor inst, gm, vrm in zip(all_data, guarda_mask, vilareal_mask):\n    try:\n        yr = int(str(inst["date"])[:4]); rd = float(inst["precipitation_sum"]) &gt;= 1.0\n        if gm: gy[yr] = gy.get(yr, 0) + (1 if rd else 0)\n        if vrm: vry[yr] = vry.get(yr, 0) + (1 if rd else 0)\n    except: pass\n\nga = np.array([v for k,v in sorted(gy.items()) if k &lt; 2026])\nvra = np.array([v for k,v in sorted(vry.items()) if k &lt; 2026])\ng_rd_ci = stats.t.interval(0.95, df=len(ga)-1, loc=np.mean(ga), scale=stats.sem(ga))\nvr_rd_ci = stats.t.interval(0.95, df=len(vra)-1, loc=np.mean(vra), scale=stats.sem(vra))\n\ndom = Domain([\n    ContinuousVariable("G_precip_mean"), ContinuousVariable("G_precip_CI_low"), ContinuousVariable("G_precip_CI_high"),\n    ContinuousVariable("VR_precip_mean"), ContinuousVariable("VR_precip_CI_low"), ContinuousVariable("VR_precip_CI_high"),\n    ContinuousVariable("G_rain_days_mean"), ContinuousVariable("G_rd_CI_low"), ContinuousVariable("G_rd_CI_high"),\n    ContinuousVariable("VR_rain_days_mean"), ContinuousVariable("VR_rd_CI_low"), ContinuousVariable("VR_rd_CI_high"),\n])\nout_data = Table.from_numpy(dom, np.array([[np.mean(g_p), g_ci[0], g_ci[1],\n    np.mean(vr_p), vr_ci[0], vr_ci[1], np.mean(ga), g_rd_ci[0], g_rd_ci[1],\n    np.mean(vra), vr_rd_ci[0], vr_rd_ci[1]]]))\nprint("CI Guarda precip:", [round(x,3) for x in g_ci])\nprint("CI VR precip:", [round(x,3) for x in vr_ci])\n', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xab\x00\x00\x00k\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
