		<properties node_id="17" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83\x00\x00\x00\x00\x00\x04\x00\x00\x05\xa0\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x05\x9f\x00\x00\x03\x83', 'scriptLibrary': [{'name': 'Default', 'script': 'out_data = in_data\n', 'filename': None}], 'scriptText': 'import numpy as np\nfrom scipy import stats\nfrom Orange.data import Table, Domain, ContinuousVariable\n\nall_data = in_data\n\n# Ver o nome exato da zona\nzone_values = list(set([str(inst["zone"]) for inst in all_data]))\nprint("Zonas encontradas:", zone_values)\n\nguarda_mask = [str(inst["zone"]) == zone_values[0] for inst in all_data]\nvilareal_mask = [str(inst["zone"]) == zone_values[1] for inst in all_data]\n\ng_precip = np.array([float(inst["precipitation_sum"]) for inst, m in zip(all_data, guarda_mask) if m])\nvr_precip = np.array([float(inst["precipitation_sum"]) for inst, m in zip(all_data, vilareal_mask) if m])\n\nprint("N Guarda:", len(g_precip), "N VilaReal:", len(vr_precip))\n\nt_stat, p_value = stats.ttest_ind(g_precip, vr_precip, equal_var=False)\ng_mean = np.mean(g_precip); g_std = np.std(g_precip, ddof=1)\nvr_mean = np.mean(vr_precip); vr_std = np.std(vr_precip, ddof=1)\npooled_std = np.sqrt((g_std**2 + vr_std**2) / 2)\ncohens_d = abs(vr_mean - g_mean) / pooled_std\n\ndomain = Domain([\n    ContinuousVariable("Guarda_mean"), ContinuousVariable("Guarda_std"),\n    ContinuousVariable("VilaReal_mean"), ContinuousVariable("VilaReal_std"),\n    ContinuousVariable("t_statistic"), ContinuousVariable("p_value"),\n    ContinuousVariable("cohens_d"), ContinuousVariable("n_Guarda"),\n    ContinuousVariable("n_VilaReal"),\n])\nout_data = Table.from_numpy(domain, np.array([[g_mean, g_std, vr_mean, vr_std, t_stat, p_value, cohens_d, len(g_precip), len(vr_precip)]]))\nprint("t=", round(t_stat,3), "p=", round(p_value,6), "d=", round(cohens_d,3))', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xab\x00\x00\x00k\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
